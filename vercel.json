{
  "version": 2,
  "builds": [
    {
      "src": "api/telegram-form.js",
      "use": "@vercel/node"
    },
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/telegram-form",
      "headers": {
        "X-Content-Type-Options": "nosniff",
        "Referrer-Policy": "same-origin"
      },
      "dest": "/api/telegram-form.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/premio-caso-aperto-noir-2026",
      "dest": "/premio-caso-aperto-noir-2026.html"
    },
    {
      "src": "/contatti",
      "dest": "/contatti.html"
    },
    {
      "src": "/collabora",
      "dest": "/collabora.html"
    },
    {
      "src": "/privacy",
      "dest": "/privacy.html"
    },
    {
      "src": "/cookie",
      "dest": "/cookie.html"
    },
    {
      "src": "/termini",
      "dest": "/termini.html"
    },
    {
      "src": "/grazie",
      "dest": "/grazie.html"
    }
  ]
}
